// ── QUERY PATTERN DETECTION ─────────────────────────────────────────────────────
interface QueryContext {
  type: 'BATTING' | 'BOWLING' | 'COMPARISON' | 'SUPER_OVER' | 'VS' | 'GENERAL';
  usesMV: boolean;
  mvHint: string;
  rules: string;
  entities: {
    players: string[];
    teams: string[];
    seasons: number[];
  };
}

function analyzeQuery(question: string): QueryContext {
  const lower = question.toLowerCase();
  
  // Detect type and recommend MV
  let type: QueryContext['type'] = 'GENERAL';
  let usesMV = false;
  let mvHint = '';
  let rules = '';
  
  if (/super\s*over/i.test(question)) {
    type = 'SUPER_OVER';
    usesMV = true;
    mvHint = 'Use player_innings_mv or bowler_performance_mv WHERE innings_type = "super_over"';
    rules = CRICKET_RULES.SUPER_OVER;
  } else if (/\b(vs|versus|against)\b/i.test(question)) {
    type = 'VS';
    usesMV = true;
    mvHint = 'Use opposition_team or batting_team columns from MVs';
    rules = CRICKET_RULES.VS_QUERIES;
  } else if (/\b(bowl|wicket|economy|maiden)\b/i.test(question)) {
    type = 'BOWLING';
    usesMV = true;
    mvHint = 'USE bowler_performance_mv - has correct economy rate with extras handled';
    rules = CRICKET_RULES.BOWLING_STATS + '\n' + CRICKET_RULES.ECONOMY_RATE;
  } else if (/\b(bat|run|century|fifty|strike\s*rate|duck|average)\b/i.test(question)) {
    type = 'BATTING';
    usesMV = true;
    mvHint = 'USE player_innings_mv for innings details or player_career_stats_mv for overall';
    rules = CRICKET_RULES.BATTING_STATS;
  } else if (/\b(best|top|compare|rank|highest|most)\b/i.test(question)) {
    type = 'COMPARISON';
    usesMV = true;
    mvHint = 'Use MVs with RANK() or DENSE_RANK() window functions';
    rules = 'Include top 10 for comparison. Use RANK() OVER (ORDER BY ...) for rankings';
  }
  
  // Extract entities
  const players = extractNames(question, 'player');
  const teams = extractNames(question, 'team');
  const seasons = (question.match(/\b(19|20)\d{2}\b/g) || []).map(Number);
  
  return {
    type,
    usesMV,
    mvHint,
    rules,
    entities: { players, teams, seasons }
  };
}

function extractNames(text: string, type: 'player' | 'team'): string[] {
  const names: string[] = [];
  
  if (type === 'player') {
    // Common player name patterns
    const patterns = [
      /\b(Kohli|Virat|King)\b/i,
      /\b(Dhoni|MSD|Mahi|Thala|MS)\b/i,
      /\b(Rohit|Sharma|Hitman)\b/i,
      /\b(Bumrah|Jasprit|Boom)\b/i,
      /\b(Jadeja|Jaddu|Sir)\b/i,
      /\b(Gayle|Chris|Universe Boss)\b/i,
      /\b(Warner|David|Bull)\b/i,
      /\b(ABD|AB|de Villiers)\b/i,
      /\b(Raina|Suresh|Chinna)\b/i,
      /\b(Pandya|Hardik)\b/i
    ];
    
    patterns.forEach(pattern => {
      if (pattern.test(text)) {
        names.push(text.match(pattern)![1]);
      }
    });
  } else {
    // Team patterns
    const teamMap: Record<string, string[]> = {
      'Chennai': ['CSK', 'Chennai', 'Super Kings', 'Yellow'],
      'Mumbai': ['MI', 'Mumbai', 'Indians', 'Paltan'],
      'Bangalore': ['RCB', 'Bangalore', 'Challengers', 'Royal'],
      'Kolkata': ['KKR', 'Kolkata', 'Knight Riders'],
      'Delhi': ['DC', 'Delhi', 'Capitals', 'DD'],
      'Hyderabad': ['SRH', 'Hyderabad', 'Sunrisers'],
      'Rajasthan': ['RR', 'Rajasthan', 'Royals'],
      'Punjab': ['PBKS', 'Punjab', 'Kings', 'KXIP']
    };
    
    Object.entries(teamMap).forEach(([team, aliases]) => {
      aliases.forEach(alias => {
        if (new RegExp(`\\b${alias}\\b`, 'i').test(text)) {
          names.push(team);
        }
      });
    });
  }
  
  return [...new Set(names)];
}

// ── ENTITY RESOLUTION ───────────────────────────────────────────────────────────
async function resolveEntities(context: QueryContext): Promise<Record<string, any>> {
  const resolved: Record<string, any> = {};
  
  // Try to resolve player names
  for (const player of context.entities.players) {
    const { data } = await supabase
      .from('entity_search')
      .select('entity_id, primary_name')
      .eq('entity_type', 'player')
      .or(`primary_name.ilike.%${player}%,search_tokens.cs.{${player.toLowerCase()}}`)
      .limit(1)
      .single();
    
    if (data) {
      resolved[player] = data;
    }
  }
  
  // Try to resolve team names
  for (const team of context.entities.teams) {
    const { data } = await supabase
      .from('entity_search')
      .select('entity_id, primary_name')
      .eq('entity_type', 'team')
      .or(`primary_name.ilike.%${team}%,search_tokens.cs.{${team.toLowerCase()}}`)
      .limit(1)
      .single();
    
    if (data) {
      resolved[team] = data;
    }
  }
  
  return resolved;
}

// ── SQL GENERATION WITH GEMINI ──────────────────────────────────────────────────
async function generateSQL(
  question: string, 
  context: QueryContext,
  resolvedEntities: Record<string, any>
): Promise<{ sql: string, explanation: string }> {
  
  // For MVP, use templates for common queries
  const sql = await tryTemplates(question, context, resolvedEntities);
  if (sql) {
    return { 
      sql, 
      explanation: `Used optimized template for ${context.type} query` 
    };
  }
  
  // If Gemini is available, use it
  if (GEMINI_API_KEY) {
    return await generateWithGemini(question, context, resolvedEntities);
  }
  
  // Fallback to basic patterns
  return generateFallbackSQL(question, context, resolvedEntities);
}

async function tryTemplates(
  question: string, 
  context: QueryContext,
  entities: Record<string, any>
): Promise<string | null> {
  
  const lower = question.toLowerCase();
  
  // Common template patterns
  if (context.type === 'BATTING' && context.entities.players.length > 0) {
    const playerName = entities[context.entities.players[0]]?.primary_name || context.entities.players[0];
    
    if (lower.includes('stats') || lower.includes('performance')) {
      return `
        SELECT 
          player_name,
          COUNT(DISTINCT match_id) as matches,
          SUM(runs_scored) as total_runs,
          ROUND(AVG(runs_scored), 2) as avg_runs_per_innings,
          MAX(runs_scored) as highest_score,
          ROUND(AVG(strike_rate), 2) as avg_strike_rate,
          SUM(CASE WHEN innings_category = 'century' THEN 1 ELSE 0 END) as centuries,
          SUM(CASE WHEN innings_category = 'fifty' THEN 1 ELSE 0 END) as fifties,
          SUM(CASE WHEN innings_category = 'duck' THEN 1 ELSE 0 END) as ducks
        FROM player_innings_mv
        WHERE player_name ILIKE '%${playerName}%'
          AND innings_type = 'regular'
        GROUP BY player_name`;
    }
    
    if (lower.includes('average')) {
      return `
        SELECT 
          player_name,
          matches_played,
          total_runs,
          batting_average,
          career_strike_rate,
          centuries,
          fifties
        FROM player_career_stats_mv
        WHERE player_name ILIKE '%${playerName}%'
          AND innings_type = 'regular'`;
    }
  }
  
  if (context.type === 'BOWLING' && context.entities.players.length > 0) {
    const playerName = entities[context.entities.players[0]]?.primary_name || context.entities.players[0];
    
    if (lower.includes('economy')) {
      return `
        SELECT 
          bowler_name,
          COUNT(DISTINCT match_id) as matches,
          SUM(wickets) as total_wickets,
          ROUND(AVG(economy_rate), 2) as avg_economy_rate,
          MIN(economy_rate) as best_economy,
          ROUND(AVG(bowling_strike_rate), 2) as avg_strike_rate,
          ROUND(AVG(dot_ball_percentage), 2) as avg_dot_ball_pct
        FROM bowler_performance_mv
        WHERE bowler_name ILIKE '%${playerName}%'
          AND innings_type = 'regular'
        GROUP BY bowler_name`;
    }
  }
  
  if (lower.includes('top') && lower.includes('scorer')) {
    const year = context.entities.seasons[0] || 2024;
    return `
      SELECT 
        player_name,
        COUNT(DISTINCT match_id) as matches,
        SUM(runs_scored) as total_runs,
        ROUND(AVG(runs_scored), 2) as avg_runs,
        MAX(runs_scored) as highest_score,
        SUM(CASE WHEN innings_category = 'century' THEN 1 ELSE 0 END) as centuries,
        SUM(CASE WHEN innings_category = 'fifty' THEN 1 ELSE 0 END) as fifties
      FROM player_innings_mv
      WHERE season_year = ${year}
        AND innings_type = 'regular'
      GROUP BY player_name
      ORDER BY total_runs DESC
      LIMIT 10`;
  }
  
  return null;
}

async function generateWithGemini(
  question: string,
  context: QueryContext,
  entities: Record<string, any>
): Promise<{ sql: string, explanation: string }> {
  
  const prompt = `You are a PostgreSQL expert for cricket analytics.

${SCHEMA_CONTEXT}

CRITICAL RULES:
${context.rules}

HINT: ${context.mvHint}

RESOLVED ENTITIES:
${JSON.stringify(entities, null, 2)}

Generate ONLY a SELECT query for: ${question}

Return in this format:
\`\`\`sql
SELECT ...
\`\`\`

EXPLANATION: Brief explanation`;

  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=${GEMINI_API_KEY}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ role: 'user', parts: [{ text: prompt }] }],
          generationConfig: { temperature: 0.1, maxOutputTokens: 1024 }
        })
      }
    );
    
    if (!response.ok) throw new Error('Gemini API error');
    
    const data = await response.json();
    const text = data?.candidates?.[0]?.content?.parts?.[0]?.text || '';
    
    const sqlMatch = text.match(/```(?:sql)?\s*([\s\S]*?)```/);
    const sql = sqlMatch ? sqlMatch[1].trim() : '';
    
    const explMatch = text.match(/EXPLANATION:\s*([\s\S]*?)$/);
    const explanation = explMatch ? explMatch[1].trim() : 'Query generated successfully';
    
    return { sql, explanation };
  } catch (error) {
    console.error('Gemini error:', error);
    return generateFallbackSQL(question, context, entities);
  }
}

function generateFallbackSQL(
  question: string,
  context: QueryContext,
  entities: Record<string, any>
): { sql: string, explanation: string } {
  
  // Basic fallback for common patterns
  let sql = '';
  
  switch (context.type) {
    case 'BATTING':
      sql = `
        SELECT 
          player_name,
          COUNT(DISTINCT match_id) as matches,
          SUM(runs_scored) as total_runs,
          ROUND(AVG(runs_scored), 2) as avg_runs
        FROM player_innings_mv
        WHERE innings_type = 'regular'
        GROUP BY player_name
        ORDER BY total_runs DESC
        LIMIT 20`;
      break;
      
    case 'BOWLING':
      sql = `
        SELECT 
          bowler_name,
          COUNT(DISTINCT match_id) as matches,
          SUM(wickets) as total_wickets,
          ROUND(AVG(economy_rate), 2) as avg_economy
        FROM bowler_performance_mv
        WHERE innings_type = 'regular'
        GROUP BY bowler_name
        ORDER BY total_wickets DESC
        LIMIT 20`;
      break;
      
    default:
      sql = `
        SELECT 
          'Please be more specific' as message,
          'Try asking about batting stats, bowling economy, or player comparisons' as suggestion`;
  }
  
  return { 
    sql, 
    explanation: 'Used fallback query pattern' 
  };
}

// ── SQL VALIDATION & EXECUTION ──────────────────────────────────────────────────
function validateSQL(sql: string): { valid: boolean, error?: string } {
  // Security checks
  const forbidden = /\b(INSERT|UPDATE|DELETE|DROP|ALTER|CREATE|TRUNCATE|GRANT|REVOKE)\b/i;
  if (forbidden.test(sql)) {
    return { valid: false, error: 'Only SELECT queries allowed' };
  }
  
  // Check for SELECT
  if (!/^\s*(WITH|SELECT)/i.test(sql)) {
    return { valid: false, error: 'Query must start with SELECT or WITH' };
  }
  
  // Add LIMIT if missing
  if (!/\bLIMIT\b/i.test(sql) && !/\bGROUP\s+BY\b/i.test(sql)) {
    sql += ' LIMIT 100';
  }
  
  return { valid: true };
}

async function executeSQL(sql: string): Promise<{ columns: string[], rows: any[], error?: string }> {
  try {
    // Use direct pool connection if available
    if (pool) {
      const client = await pool.connect();
      try {
        await client.queryArray(`SET statement_timeout = '5s'`);
        const result = await client.queryObject(sql);
        
        const columns = result.fields?.map((f: any) => f.name) || 
                       (result.rows[0] ? Object.keys(result.rows[0]) : []);
        
        return { 
          columns,
          rows: result.rows.map((r: any) => 
            Object.fromEntries(
              Object.entries(r).map(([k, v]) => [
                k, 
                typeof v === 'bigint' ? v.toString() : v
              ])
            )
          )
        };
      } finally {
        client.release();
      }
    }
    
    // Fallback to Supabase client (limited to simple queries)
    const { data, error } = await supabase.rpc('execute_sql', { query: sql });
    if (error) throw error;
    
    return {
      columns: data?.[0] ? Object.keys(data[0]) : [],
      rows: data || []
    };
    
  } catch (error: any) {
    console.error('SQL execution error:', error);
    return { 
      columns: [], 
      rows: [], 
      error: error.message || 'Query execution failed' 
    };
  }
}

// ── ANSWER GENERATION ───────────────────────────────────────────────────────────
async function generateAnswer(
  question: string,
  results: any,
  context: QueryContext
): Promise<string> {
  
  if (!results.rows || results.rows.length === 0) {
    return 'No data found for your query. Try using player surnames (e.g., "Kohli" instead of "V Kohli") or team abbreviations (e.g., "CSK" for Chennai).';
  }
  
  // For comparison queries, provide ranking
  if (context.type === 'COMPARISON') {
    const topRows = results.rows.slice(0, 5);
    let answer = `Based on the data:\n\n`;
    
    topRows.forEach((row: any, idx: number) => {
      const name = row.player_name || row.bowler_name || row.team_name || 'Unknown';
      const metric = row.total_runs || row.total_wickets || row.batting_average || row.economy_rate;
      answer += `${idx + 1}. ${name}: ${metric}\n`;
    });
    
    return answer;
  }
  
  // For specific player queries
  if (context.entities.players.length > 0 && results.rows.length === 1) {
    const row = results.rows[0];
    const stats = [];
    
    if (row.batting_average) stats.push(`Batting Average: ${row.batting_average}`);
    if (row.total_runs) stats.push(`Total Runs: ${row.total_runs}`);
    if (row.total_wickets) stats.push(`Total Wickets: ${row.total_wickets}`);
    if (row.economy_rate) stats.push(`Economy Rate: ${row.economy_rate}`);
    if (row.centuries) stats.push(`Centuries: ${row.centuries}`);
    if (row.fifties) stats.push(`Fifties: ${row.fifties}`);
    
    return `${row.player_name || row.bowler_name} Statistics:\n${stats.join('\n')}`;
  }
  
  // Generic summary
  return `Found ${results.rows.length} results. The top entry is ${JSON.stringify(results.rows[0], null, 2)}`;
}

// ── SIMPLE CACHING ──────────────────────────────────────────────────────────────
const queryCache = new Map<string, any>();
const CACHE_TTL = 5 * 60 * 1000; // 5 minutes

function getCached(key: string): any | null {
  const cached = queryCache.get(key);
  if (cached && Date.now() - cached.timestamp < CACHE_TTL) {
    return cached.data;
  }
  queryCache.delete(key);
  return null;
}

function setCache(key: string, data: any): void {
  queryCache.set(key, { data, timestamp: Date.now() });
  
  // Limit cache size
  if (queryCache.size > 100) {
    const firstKey = queryCache.keys().next().value;
    queryCache.delete(firstKey);
  }
}

// ── MAIN HANDLER ────────────────────────────────────────────────────────────────
Deno.serve(async (req) => {
  // Handle CORS
  if (req.method === 'OPTIONS') {
    return new Response(null, { headers: corsHeaders });
  }
  
  const startTime = Date.now();
  
  try {
    // Parse request
    const { question, useCache = true } = await req.json();
    
    if (!question || typeof question !== 'string') {
      return jsonResponse({ error: 'Missing or invalid question' }, 400);
    }
    
    // Check cache
    const cacheKey = question.toLowerCase().trim();
    if (useCache) {
      const cached = getCached(cacheKey);
      if (cached) {
        return jsonResponse({
          ...cached,
          metadata: {
            ...cached.metadata,
            cached: true,
            executionTime: Date.now() - startTime
          }
        });
      }
    }
    
    // Analyze query
    const context = analyzeQuery(question);
    
    // Resolve entities
    const resolvedEntities = await resolveEntities(context);
    
    // Generate SQL
    const { sql, explanation } = await generateSQL(question, context, resolvedEntities);
    
    if (!sql) {
      return jsonResponse({
        error: 'Failed to generate SQL query',
        suggestion: 'Please try rephrasing your question'
      }, 400);
    }
    
    // Validate SQL
    const validation = validateSQL(sql);
    if (!validation.valid) {
      return jsonResponse({
        error: validation.error,
        sql,
        suggestion: 'Query validation failed'
      }, 400);
    }
    
    // Execute SQL
    const results = await executeSQL(sql);
    
    if (results.error) {
      return jsonResponse({
        error: results.error,
        sql,
        suggestion: 'Try a simpler query or check the data'
      }, 500);
    }
    
    // Generate answer
    const answer = await generateAnswer(question, results, context);
    
    // Prepare response
    const response = {
      sql,
      columns: results.columns,
      rows: results.rows,
      rowCount: results.rows.length,
      answer,
      explanation,
      metadata: {
        queryType: context.type,
        usedMaterializedView: context.usesMV,
        executionTime: Date.now() - startTime,
        resolvedEntities: Object.keys(resolvedEntities).length > 0 ? resolvedEntities : null
      }
    };
    
    // Cache successful results
    if (results.rows.length > 0 && useCache) {
      setCache(cacheKey, response);
    }
    
    return jsonResponse(response);
    
  } catch (error: any) {
    console.error('Handler error:', error);
    
    return jsonResponse({
      error: error.message || 'Internal server error',
      timestamp: new Date().toISOString(),
      suggestion: 'An unexpected error occurred. Please try again.'
    }, 500);
  }
});